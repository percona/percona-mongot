Rewrite bazel_rules_mongo's BUILDs to reference @poetry_bazel_rules_mongo
directly, bypassing the @poetry//:dependencies.bzl `dependency()` macro.

The macro emits labels with the bzlmod canonical prefix baked in, so they
cannot be redirected via the consuming repo's repo_mapping. Inlining the
`:library_<pkg>` targets sidesteps the indirection entirely.

The `@poetry_bazel_rules_mongo` apparent name resolves from inside
bazel_rules_mongo because both repos are declared at the root module level
(in bazel/common/common.MODULE.bazel via `use_repo_rule`) and bzlmod
propagates root-module apparent names into the repo_mappings of root-declared
external repos.

--- a/codeowners/BUILD.bazel	2026-05-26 16:19:25
+++ b/codeowners/BUILD.bazel	2026-05-26 16:19:43
@@ -1,5 +1,3 @@
-load("@poetry//:dependencies.bzl", "dependency")
-
 py_binary(
     name = "codeowners",
     srcs = [
@@ -40,12 +38,8 @@
     main = "codeowners_generate.py",
     visibility = ["//visibility:public"],
     deps = [
-        dependency(
-            "pyyaml",
-        ),
-        dependency(
-            "gitpython",
-        ),
+        "@poetry_bazel_rules_mongo//:library_pyyaml",
+        "@poetry_bazel_rules_mongo//:library_gitpython",
     ],
 )
 
--- a/engflow_auth/BUILD.bazel	2026-05-26 16:19:25
+++ b/engflow_auth/BUILD.bazel	2026-05-26 16:19:55
@@ -1,13 +1,7 @@
-load("@poetry//:dependencies.bzl", "dependency")
-
 py_binary(
     name = "engflow_auth",
     srcs = ["engflow_auth.py"],
     main = "engflow_auth.py",
     visibility = ["//visibility:public"],
-    deps = [
-        dependency(
-            "retry",
-        ),
-    ],
+    deps = ["@poetry_bazel_rules_mongo//:library_retry"],
 )

{
  "tests": [
    {
      "description": "simple",
      "json": {
        "syncSource": {
          "replicaSet": {
            "hostAndPort": "mongod:27017",
            "scramAuth": {
              "authSource": "admin",
              "username": "user",
              "passwordFile": "/etc/mongot/replicaSet.passwd",
              "tls": {
                "enabled": false
              }
            }
          }
        },
        "storage": {
          "dataPath": "data/mongot"
        },
        "server": {
          "grpc": {
            "address": "localhost:27028",
            "tls": {
              "mode": "MTLS",
              "certificateKeyFile": "/etc/ssl/common-cert.pem",
              "caFile": "/etc/mongot-tls/ca.pem"
            }
          },
          "name": "server-name"
        },
        "metrics": {
          "enabled": true,
          "address": "localhost:9946"
        },
        "healthCheck": {
          "address": "localhost:8080"
        },
        "logging": {
          "verbosity": "DEBUG",
          "logPath": "/var/log/mongot"
        },
        "ftdc": {
          "enabled": true,
          "directorySizeMb": 100,
          "fileSizeMb": 10,
          "collectionPeriodMillis": 1000
        },
        "diskMonitor": {
          "pauseReplicationThreshold": 0.9,
          "resumeReplicationThreshold": 0.85,
          "crashThreshold": 0.95,
          "pauseInitialSyncThreshold": 0.85,
          "resumeInitialSyncThreshold": 0.8
        }
      },
      "bson": {
        "syncSource": {
          "replicaSet": {
            "hostAndPort": "mongod:27017",
            "scramAuth": {
              "authSource": "admin",
              "username": "user",
              "passwordFile": "/etc/mongot/replicaSet.passwd",
              "tls": {
                "enabled": false
              }
            }
          }
        },
        "storage": {
          "dataPath": "data/mongot"
        },
        "server": {
          "grpc": {
            "address": "localhost:27028",
            "tls": {
              "mode": "MTLS",
              "certificateKeyFile": "/etc/ssl/common-cert.pem",
              "caFile": "/etc/mongot-tls/ca.pem"
            }
          },
          "name": "server-name"
        },
        "metrics": {
          "enabled": true,
          "address": "localhost:9946"
        },
        "healthCheck": {
          "address": "localhost:8080"
        },
        "logging": {
          "verbosity": "DEBUG",
          "logPath": "/var/log/mongot"
        },
        "ftdc": {
          "enabled": true,
          "directorySizeMb": 100,
          "fileSizeMb": 10,
          "collectionPeriodMillis": 1000
        },
        "diskMonitor": {
          "pauseReplicationThreshold": 0.9,
          "resumeReplicationThreshold": 0.85,
          "crashThreshold": 0.95,
          "pauseInitialSyncThreshold": 0.85,
          "resumeInitialSyncThreshold": 0.8
        }
      }
    }
  ]
}

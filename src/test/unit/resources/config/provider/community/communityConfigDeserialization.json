    {
      "description": "full",
      "value": {
        "syncSource": {
          "replicaSet": {
            "hostAndPort": [
              "mongod1:27017",
              "mongod2:27017"
            ],
            "scramAuth": {
              "authSource": "local",
              "username": "user",
              "passwordFile": "/etc/mongot/replicaSet.passwd",

                "enabled": true,
                "tlsCertificateKeyFile": "/etc/mongot/tls/client-combined.pem",
                "caFile": "/etc/mongot/ca.pem"
              }
            },
            "readPreference": "primaryPreferred"
          },
          "router": {
            "hostAndPort": [
              "mongos1:27017",
              "mongos2:27017"
            ],
            "scramAuth": {
              "authSource": "local",
